<?xml version="1.0" encoding="utf-8"?>
<!-- Disable Auto Backup of sensitive data -->
<full-backup-content>
    <exclude domain="database" path="posbah.db" />
    <exclude domain="database" path="posbah.db-journal" />
    <exclude domain="database" path="posbah.db-shm" />
    <exclude domain="database" path="posbah.db-wal" />
    <exclude domain="sharedpref" path="posbah_secure_prefs.xml" />
    <exclude domain="sharedpref" path="posbah_session.xml" />
</full-backup-content>
