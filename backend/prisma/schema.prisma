datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  /// Valid values: KASIR | ADMIN | OWNER
  /// KASIR  - transaksi & lihat katalog saja
  /// ADMIN  - kelola produk, pelanggan, keuangan
  /// OWNER  - akses penuh termasuk kelola karyawan
  role      String   @default("KASIR")
  pin       String
  salary    Float    @default(0)           // Gaji pokok per bulan
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  transactions Transaction[]
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  transactions Transaction[]
  receivables Finance[] @relation("CustomerReceivables")
}

model Product {
  id               Int      @id @default(autoincrement())
  name             String
  price            Float                          // Harga Jual
  costPrice        Float    @default(0)           // Harga Modal
  stock            Int      @default(0)
  unit             String   @default("pcs")
  barcode          String?  @unique               // Barcode EAN-13 / QR
  wholesaleEnabled Boolean  @default(false)
  wholesalePrices  String?                        // JSON: [{minQty, price}, ...]
  variants         String?                        // JSON: [{name, stock?, price?, attrs?}, ...]
  image            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  transactionItems TransactionItem[]
  purchaseItems    PurchaseOrderItem[]
}

model Transaction {
  id              Int      @id @default(autoincrement())
  receiptNumber   String   @unique
  date            DateTime @default(now())

  // Keuangan — dipisah untuk laporan omzet vs diskon
  subtotal        Float    @default(0)           // Harga kotor sebelum diskon
  discountType    String?                        // "percent" | "nominal" | null
  discountInput   Float    @default(0)           // Nilai input user (10 = 10%, atau 5000 = Rp5000)
  discountAmt     Float    @default(0)           // Rupiah yang benar-benar dipotong
  total           Float                          // Grand total = subtotal - discountAmt
  discount        Float    @default(0)           // Legacy — tetap ada agar data lama aman

  paymentMethod   String   // QRIS, CASH, TRANSFER
  amountPaid      Float?                         // Uang yang dibayar pelanggan
  change          Float?                         // Kembalian
  status          String   @default("COMPLETED") // COMPLETED, CANCELLED
  type            String   @default("SALES")     // SALES, BACKDATE, PRE_ORDER

  // Pre-Order fields
  orderStatus     String?                        // BOOKED, DP_PAID, COMPLETED
  dpAmount        Float    @default(0)
  deliveryDate    DateTime?

  employeeId      Int
  employee        Employee @relation(fields: [employeeId], references: [id])

  customerId      Int?
  customer        Customer? @relation(fields: [customerId], references: [id])
  customerName    String?
  queueNumber     Int?
  notes           String?

  items           TransactionItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TransactionItem {
  id            Int      @id @default(autoincrement())
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  productId     Int
  product       Product @relation(fields: [productId], references: [id])
  variantId     Int?                             // ID varian jika ada
  variantName   String?                          // Nama varian (misal: "Milo Almond")

  quantity      Int
  price         Float                            // Harga jual per unit saat transaksi
  costPrice     Float    @default(0)             // Harga modal per unit (untuk laporan HPP)
  discount      Float    @default(0)             // Diskon per item (legacy)
  note          String?                          // Catatan item (misal: "Less ice")
}

model Finance {
  id          Int      @id @default(autoincrement())
  type        String   // PAYABLE (Hutang), RECEIVABLE (Piutang), EXPENSE (Pengeluaran Usaha)
  amount      Float
  description String
  date        DateTime @default(now())
  status      String   @default("PENDING") // PENDING, PAID
  
  customerId  Int?
  customer    Customer? @relation("CustomerReceivables", fields: [customerId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Promo {
  id          Int      @id @default(autoincrement())
  name        String
  type        String   // PRODUCT, TRANSACTION
  value       Float    // Discount percentage or flat amount
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Supplier & Purchase Order ─────────────────────────────────
model Supplier {
  id             Int             @id @default(autoincrement())
  name           String
  phone          String?
  address        String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id          Int                @id @default(autoincrement())
  supplierId  Int
  supplier    Supplier           @relation(fields: [supplierId], references: [id])
  date        DateTime           @default(now())
  status      String             @default("DRAFT") // DRAFT, ORDERED, RECEIVED
  notes       String?
  total       Float              @default(0)
  items       PurchaseOrderItem[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model PurchaseOrderItem {
  id               Int           @id @default(autoincrement())
  purchaseOrderId  Int
  purchaseOrder    PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId        Int
  product          Product        @relation(fields: [productId], references: [id])
  quantity         Int
  costPrice        Float          // Harga beli per unit saat PO
}
