<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Cetak Slip Gaji - 4 Kolom</title>
    <style>
        @page {
            size: 9.5in 11in;
            margin: 0.3in;
        }

        body {
            font-family: 'Courier New', Courier, monospace;
            font-size: 12px;
            background-color: #fff;
            color: #000;
            margin: 0;
            padding: 0;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .grid-container {
            width: 100%;
            overflow: hidden;
        }

        .slip-box {
            width: 23%;
            float: left;
            margin-right: 1.5%;
            margin-bottom: 20px;
            border: 1px dashed #666;
            padding: 15px;
            min-height: 300px;
            box-sizing: border-box;
            page-break-inside: avoid;
            background: #fff;
        }

        .slip-box:nth-child(4n) {
            margin-right: 0;
        }

        .header {
            text-align: center;
            border-bottom: 2px solid #000;
            padding-bottom: 8px;
            margin-bottom: 15px;
        }

        .header h2 { margin: 0; font-size: 14px; font-weight: bold; text-transform: uppercase; }
        .header p { margin: 4px 0 0 0; font-size: 10px; }

        .row { display: flex; justify-content: space-between; margin-bottom: 8px; }
        .row-title { font-weight: bold; }

        .bonus-section {
            border-top: 1px dashed #999;
            margin: 8px 0;
            padding-top: 8px;
            font-size: 11px;
        }
        .bonus-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 4px;
            color: #333;
        }
        .bonus-label { font-style: italic; }

        .total-section {
            border-top: 1px dashed #ccc;
            margin-top: 10px;
            padding-top: 8px;
        }

        .footer-ttd {
            margin-top: 30px;
            text-align: center;
            font-size: 11px;
        }
        .ttd-line {
            margin-top: 40px;
            border-bottom: 1px solid #000;
            width: 80%;
            display: inline-block;
        }
    </style>
</head>
<body>
<div class="grid-container">
    <% Employees.forEach(function(e) { %>
    <div class="slip-box">
        <div class="header">
            <h2>CV. BMP</h2>
            <p>Slip Gaji Karyawan</p>
        </div>

        <div class="row">
            <span class="row-title">Nama</span>
            <span><%= (e.Payroll.employee && e.Payroll.employee.name) ? e.Payroll.employee.name : "-" %></span>
        </div>
        <div class="row">
            <span class="row-title">Bagian</span>
            <span><%= (e.Payroll.employee && e.Payroll.employee.position) ? e.Payroll.employee.position : "-" %></span>
        </div>
        <div class="row">
            <span class="row-title">Keterangan</span>
            <span style="text-align: right; max-width: 60%;"><%= e.Payroll.description ? e.Payroll.description : "-" %></span>
        </div>

        <div style="border-top: 1px dashed #ccc; margin: 10px 0;"></div>

        <div class="row">
            <span class="row-title">Gaji Pokok</span>
            <span>Rp<%= formatRpComma(e.Payroll.amount) %></span>
        </div>

        <% if (e.BonusLogs && e.BonusLogs.length > 0) { %>
        <div class="bonus-section">
            <div style="font-weight: bold; margin-bottom: 5px;">Bonus Mesin:</div>
            <% e.BonusLogs.forEach(function(b) { %>
            <div class="bonus-row">
                <span class="bonus-label"><%= b.machineName %> (<%= b.shiftType %>)<%= b.jumlahPerolehan ? " - " + b.jumlahPerolehan + " tumpukan" : "" %></span>
                <span>Rp<%= formatRpComma(b.bonusAmount) %></span>
            </div>
            <% }) %>
        </div>
        <% } %>

        <div class="total-section">
            <div class="row" style="font-size: 13px; font-weight: bold;">
                <span>TOTAL</span>
                <span>Rp<%= formatRpComma(e.TotalGaji) %></span>
            </div>
            <% if (e.TotalBonus) { %>
            <div style="font-size: 10px; color: #555; text-align: right;">
                (Gaji + Bonus Rp<%= formatRpComma(e.TotalBonus) %>)
            </div>
            <% } %>
        </div>

        <div class="footer-ttd">
            Penerima,
            <div class="ttd-line"></div>
        </div>
    </div>
    <% }) %>
</div>
</body>
</html>
